    cf get110111[i][k][l]: mesh3d_exchange_6_get_11_01_11(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      `out b[$D011][i][k][l],b[$D110][i][k][l],b[$D112][i][k][l],b[$D121][i][k][l],b[$D211][i][k][l]);
    cf set110111[i][k][l]: mesh3d_exchange_6_set_11_01_11(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      b[$D211][i-1][k][l],b[$D112][i][k][l-1],b[$D110][i][k][l+1],b[$D101][i][k+1][l],b[$D011][i+1][k][l],
      `out v[i][k][l]);
  }
  for i=0..0 for k=0..0 for l=1..nf[2]-2
  {
    cf get010111[i][k][l]: mesh3d_exchange_6_get_01_01_11(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      `out b[$D110][i][k][l],b[$D112][i][k][l],b[$D121][i][k][l],b[$D211][i][k][l]);
    cf set010111[i][k][l]: mesh3d_exchange_6_set_01_01_11(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      b[$D112][i][k][l-1],b[$D110][i][k][l+1],b[$D101][i][k+1][l],b[$D011][i+1][k][l],
      `out v[i][k][l]);
  }
  for i=0..0 for k=0..0 for l=0..0
  {
    cf get010101[i][k][l]: mesh3d_exchange_6_get_01_01_01(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      `out b[$D112][i][k][l],b[$D121][i][k][l],b[$D211][i][k][l]);
    cf set010101[i][k][l]: mesh3d_exchange_6_set_01_01_01(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      b[$D110][i][k][l+1],b[$D101][i][k+1][l],b[$D011][i+1][k][l],
      `out v[i][k][l]);
  }
  for i=0..0 for k=1..nf[1]-2 for l=nf[2]-1..nf[2]-1
  {
    cf get011110[i][k][l]: mesh3d_exchange_6_get_01_11_10(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      `out b[$D101][i][k][l],b[$D110][i][k][l],b[$D121][i][k][l],b[$D211][i][k][l]);
    cf set011110[i][k][l]: mesh3d_exchange_6_set_01_11_10(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      b[$D121][i][k-1][l],b[$D112][i][k][l-1],b[$D101][i][k+1][l],b[$D011][i+1][k][l],
      `out v[i][k][l]);
  }
  for i=nf[0]-1..nf[0]-1 for k=1..nf[1]-2 for l=nf[2]-1..nf[2]-1
  {
    cf get101110[i][k][l]: mesh3d_exchange_6_get_10_11_10(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      `out b[$D011][i][k][l],b[$D101][i][k][l],b[$D110][i][k][l],b[$D121][i][k][l]);
    cf set101110[i][k][l]: mesh3d_exchange_6_set_10_11_10(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      b[$D211][i-1][k][l],b[$D121][i][k-1][l],b[$D112][i][k][l-1],b[$D101][i][k+1][l],
      `out v[i][k][l]);
  }
  for i=1..nf[0]-2 for k=1..nf[1]-2 for l=1..nf[2]-2
  {
    cf get111111[i][k][l]: mesh3d_exchange_6_get_11_11_11(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      `out b[$D011][i][k][l],b[$D101][i][k][l],b[$D110][i][k][l],b[$D112][i][k][l],b[$D121][i][k][l],b[$D211][i][k][l]);
    cf set111111[i][k][l]: mesh3d_exchange_6_set_11_11_11(`in nfs[0][i],nfs[1][k],nfs[2][l],u[i][k][l],
      b[$D211][i-1][k][l],b[$D121][i][k-1][l],b[$D112][i][k][l-1],b[$D110][i][k][l+1],b[$D101][i][k+1][l],b[$D011][i+1][k][l],
      `out v[i][k][l]);
  }
}

sub mesh3d_exchange_6(`in name nf,name nfs,name u, `out name v)
// nf  : [3] int : 3D subdomains grid sizes
// nfs : [3][] int : subdomains sizes (with borders)
// u   : [][][] real[][][] : fragmented 3D array (before exchange)
// v   : [][][] real[][][] : fragmented 3D array (after exchange)
{
  if (nf[0] == 1)
  {
    if (nf[1] == 1)
    {
      if (nf[2] == 1) cf ex111: mesh3d_exchange111_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex112: mesh3d_exchange112_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex113: mesh3d_exchange113_6(`in nf,nfs,u, `out v);
    }
    if (nf[1] == 2)
    {
      if (nf[2] == 1) cf ex121: mesh3d_exchange121_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex122: mesh3d_exchange122_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex123: mesh3d_exchange123_6(`in nf,nfs,u, `out v);
    }
    if (nf[1] >= 3)
    {
      if (nf[2] == 1) cf ex131: mesh3d_exchange131_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex132: mesh3d_exchange132_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex133: mesh3d_exchange133_6(`in nf,nfs,u, `out v);
    }
  }
  if (nf[0] == 2)
  {
    if (nf[1] == 1)
    {
      if (nf[2] == 1) cf ex211: mesh3d_exchange211_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex212: mesh3d_exchange212_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex213: mesh3d_exchange213_6(`in nf,nfs,u, `out v);
    }
    if (nf[1] == 2)
    {
      if (nf[2] == 1) cf ex221: mesh3d_exchange221_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex222: mesh3d_exchange222_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex223: mesh3d_exchange223_6(`in nf,nfs,u, `out v);
    }
    if (nf[1] >= 3)
    {
      if (nf[2] == 1) cf ex231: mesh3d_exchange231_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex232: mesh3d_exchange232_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex233: mesh3d_exchange233_6(`in nf,nfs,u, `out v);
    }
  }
  if (nf[0] >= 3)
  {
    if (nf[1] == 1)
    {
      if (nf[2] == 1) cf ex311: mesh3d_exchange311_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex312: mesh3d_exchange312_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex313: mesh3d_exchange313_6(`in nf,nfs,u, `out v);
    }
    if (nf[1] == 2)
    {
      if (nf[2] == 1) cf ex321: mesh3d_exchange321_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex322: mesh3d_exchange322_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex323: mesh3d_exchange323_6(`in nf,nfs,u, `out v);
    }
    if (nf[1] >= 3)
    {
      if (nf[2] == 1) cf ex331: mesh3d_exchange331_6(`in nf,nfs,u, `out v);
      if (nf[2] == 2) cf ex332: mesh3d_exchange332_6(`in nf,nfs,u, `out v);
      if (nf[2] >= 3) cf ex333: mesh3d_exchange333_6(`in nf,nfs,u, `out v);
    }
  }
}

