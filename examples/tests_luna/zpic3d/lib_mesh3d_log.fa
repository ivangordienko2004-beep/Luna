{
  df uxz;      // [][] real[][]
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    if (kg>=$L2G(1,nf0[1][k]) && kg<$L2G(nfs[1][k]-1,nf0[1][k]))
      cf sel: real3d_select_xz(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],nb,u[i][k][l],kg, `out uxz[i][l]);
  cf wrt: write2d_plt(`in str,it,n[0],n[2],nf[0],nf[2],nfs[0],nfs[2],nf0[0],nf0[2],1,uxz,scriptname,prev, `out next);
}

sub log_yz_plt(`in string str,int it,name n,name nf,name nfs,name nf0,int nb,name u,int ig,string scriptname,name prev, `out name next)
// str : string : part of file name
// it  : int : time step number
// n   : [3] int : 3D mesh sizes
// nf  : [3] int : 3D subdomains grid sizes
// nfs : [3][] int : subdomains sizes (with borders)
// nf0 : [3][] int : subdomains starts (global cell number) (with borders)
// nb  : int : border size
// u   : [][][] real[][][] : array to write
// ig  : int : global X index of YZ layer to save
{
  df uyz;      // [][] real[][]
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    if (ig>=$L2G(1,nf0[0][i]) && ig<$L2G(nfs[0][i]-1,nf0[0][i]))
      cf sel: real3d_select_yz(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],nb,u[i][k][l],ig, `out uyz[k][l]);
  cf wrt: write2d_plt(`in str,it,n[1],n[2],nf[1],nf[2],nfs[1],nfs[2],nf0[1],nf0[2],1,uyz,scriptname,prev, `out next);
}

//-------------------------------------------------------------------------------------------------------------------------------
// Joined,gnuplot,used output

sub log_sxy_plt_used(`in string str,int it,name n,name nf,name nfs,name nf0,int nb,name u,string scriptname,name prev, `out name next, `used name used_u)
// str : string : part of file name
// it  : int : time step number
// n   : [3] int : 3D mesh sizes
// nf  : [3] int : 3D subdomains grid sizes
// nfs : [3][] int : subdomains sizes (with borders)
// nf0 : [3][] int : subdomains starts (global cell number) (with borders)
// nb  : int : border size
// u   : [][][] real[][][] : array to write
{
  df u2d,s,    // [][][] real[][]
     uxy;      // [][] real[][]
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf sum: real3d_sum_xy(`in nfs[0][i],nfs[1][k],nfs[2][l],nb,u[i][k][l], `out u2d[i][k][l]) >> (used_u[i][k][l]);
  for i=0..nf[0]-1 for k=0..nf[1]-1 let nxy=nfs[0][i]*nfs[1][k]
  { if (nf[2]==1) cf copy: copy(`in u2d[i][k][0], `out uxy[i][k]);
    if (nf[2]==2) cf add0: real1d_add(`in nxy,u2d[i][k][0],u2d[i][k][1], `out uxy[i][k]);
    if (nf[2]>2)
    { cf add1: real1d_add(`in nxy,u2d[i][k][0],u2d[i][k][1], `out s[i][k][1]);
      for l=2..nf[2]-2 cf add2: real1d_add(`in nxy,s[i][k][l-1],u2d[i][k][l], `out s[i][k][l]);
      cf add3: real1d_add(`in nxy,s[i][k][nf[2]-2],u2d[i][k][nf[2]-1], `out uxy[i][k]);
    }
  }
  cf wrt: write2d_plt(`in str,it,n[0],n[1],nf[0],nf[1],nfs[0],nfs[1],nf0[0],nf0[1],1,uxy,scriptname,prev, `out next);
}

sub log_sxz_plt_used(`in string str,int it,name n,name nf,name nfs,name nf0,int nb,name u,string scriptname,name prev, `out name next, `used name used_u)
// str : string : part of file name
// it  : int : time step number
// n   : [3] int : 3D mesh sizes
// nf  : [3] int : 3D subdomains grid sizes
// nfs : [3][] int : subdomains sizes (with borders)
// nf0 : [3][] int : subdomains starts (global cell number) (with borders)
// nb  : int : border size
// u   : [][][] real[][][] : array to write
{
  df u2d,s,    // [][][] real[][]
     uxz;      // [][] real[][]
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf sum: real3d_sum_xz(`in nfs[0][i],nfs[1][k],nfs[2][l],nb,u[i][k][l], `out u2d[i][k][l]) >> (used_u[i][k][l]);
  for i=0..nf[0]-1 for l=0..nf[2]-1 let nxz=nfs[0][i]*nfs[2][l]
  { if (nf[1]==1) cf copy: copy(`in u2d[i][0][l], `out uxz[i][l]);
    if (nf[1]==2) cf add0: real1d_add(`in nxz,u2d[i][0][l],u2d[i][1][l], `out uxz[i][l]);
    if (nf[1]>2)
    { cf add1: real1d_add(`in nxz,u2d[i][0][l],u2d[i][1][l], `out s[i][1][l]);
      for k=2..nf[1]-2 cf add2: real1d_add(`in nxz,s[i][k-1][l],u2d[i][k][l], `out s[i][k][l]);
      cf add3: real1d_add(`in nxz,s[i][nf[1]-2][l],u2d[i][nf[1]-1][l], `out uxz[i][l]);
    }
  }
  cf wrt: write2d_plt(`in str,it,n[0],n[2],nf[0],nf[2],nfs[0],nfs[2],nf0[0],nf0[2],1,uxz,scriptname,prev, `out next);
}

sub log_syz_plt_used(`in string str,int it,name n,name nf,name nfs,name nf0,int nb,name u,string scriptname,name prev, `out name next, `used name used_u)
// str : string : part of file name
// it  : int : time step number
// n   : [3] int : 3D mesh sizes
// nf  : [3] int : 3D subdomains grid sizes
// nfs : [3][] int : subdomains sizes (with borders)
// nf0 : [3][] int : subdomains starts (global cell number) (with borders)
// nb  : int : border size
// u   : [][][] real[][][] : array to write
{
  df u2d,s,    // [][][] real[][]
     uyz;      // [][] real[][]
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf sum: real3d_sum_yz(`in nfs[0][i],nfs[1][k],nfs[2][l],nb,u[i][k][l], `out u2d[i][k][l]) >> (used_u[i][k][l]);
  for k=0..nf[1]-1 for l=0..nf[2]-1 let nyz=nfs[1][k]*nfs[2][l]
  { if (nf[0]==1) cf copy: copy(`in u2d[0][k][l], `out uyz[k][l]);
    if (nf[0]==2) cf add0: real1d_add(`in nyz,u2d[0][k][l],u2d[1][k][l], `out uyz[k][l]);
    if (nf[0]>2)
    { cf add1: real1d_add(`in nyz,u2d[0][k][l],u2d[1][k][l], `out s[1][k][l]);
      for i=2..nf[0]-2 cf add2: real1d_add(`in nyz,s[i-1][k][l],u2d[i][k][l], `out s[i][k][l]);
      cf add3: real1d_add(`in nyz,s[nf[0]-2][k][l],u2d[nf[0]-1][k][l], `out uyz[k][l]);
    }
  }
  cf wrt: write2d_plt(`in str,it,n[1],n[2],nf[1],nf[2],nfs[1],nfs[2],nf0[1],nf0[2],1,uyz,scriptname,prev, `out next);
}

sub log_xy_plt_used(`in string str,int it,name n,name nf,name nfs,name nf0,int nb,name u,int lg,string scriptname,name prev, `out name next, `used name used_u)
// str : string : part of file name
// it  : int : time step number
// n   : [3] int : 3D mesh sizes
// nf  : [3] int : 3D subdomains grid sizes
// nfs : [3][] int : subdomains sizes (with borders)
// nf0 : [3][] int : subdomains starts (global cell number) (with borders)
// nb  : int : border size
// u   : [][][] real[][][] : array to write
// lg  : int : global Z index of XY layer to save
{
  df uxy;      // [][] real[][]
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
  {
    if (lg>=$L2G(1,nf0[2][l]) && lg<$L2G(nfs[2][l]-1,nf0[2][l]))
      cf sel: real3d_select_xy(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],nb,u[i][k][l],lg, `out uxy[i][k]) >> (used_u[i][k][l]);
    if (lg<$L2G(1,nf0[2][l]) || lg>=$L2G(nfs[2][l]-1,nf0[2][l])) cf use: empty0() >> (used_u[i][k][l]);
  }
  cf wrt: write2d_plt(`in str,it,n[0],n[1],nf[0],nf[1],nfs[0],nfs[1],nf0[0],nf0[1],1,uxy,scriptname,prev, `out next);
}

