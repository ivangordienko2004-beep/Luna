// nf  : [3] int : 3D subdomains grid sizes
// nfs : [3][] int : subdomains sizes (with borders)
// nf0 : [3][] int : subdomains starts (global cell number) (with borders)
// nb  : int : border size
// u   : [][][] real[][][] : array to write
// ig  : int : global X index of YZ layer to save
{
  df uyz;      // [][] real[][]
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
  {
    if (ig>=$L2G(1,nf0[0][i]) && ig<$L2G(nfs[0][i]-1,nf0[0][i]))
      cf sel: real3d_select_yz(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],nb,u[i][k][l],ig, `out uyz[k][l]) >> (used_u[i][k][l]);
    if (ig<$L2G(1,nf0[0][i]) || ig>=$L2G(nfs[0][i]-1,nf0[0][i]))
      cf use: empty0() >> (used_u[i][k][l]);
  }
  cf wrt: write2d_split_plt(`in str,it,nf[1],nf[2],nfs[1],nfs[2],uyz,scriptname,prev, `out next);
}
