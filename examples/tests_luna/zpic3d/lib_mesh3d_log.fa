sub log_sxy_plt(`in string str,int it,name n,name nf,name nfs,name nf0,int nb,name u,string scriptname,name prev, `out name next)
// str : string : part of file name
// it  : int : time step number
// n   : [3] int : 3D mesh sizes
// nf  : [3] int : 3D subdomains grid sizes
// nfs : [3][] int : subdomains sizes (with borders)
// nf0 : [3][] int : subdomains starts (global cell number) (with borders)
// nb  : int : border size
// u   : [][][] real[][][] : array to write
{
  df u2d,s,    // [][][] real[][]
     uxy;      // [][] real[][]
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf sum: real3d_sum_xy(`in nfs[0][i],nfs[1][k],nfs[2][l],nb,u[i][k][l], `out u2d[i][k][l]);
  for i=0..nf[0]-1 for k=0..nf[1]-1 let nxy=nfs[0][i]*nfs[1][k]
  { if (nf[2]==1) cf copy: copy(`in u2d[i][k][0], `out uxy[i][k]);
    if (nf[2]==2) cf add0: real1d_add(`in nxy,u2d[i][k][0],u2d[i][k][1], `out uxy[i][k]);
    if (nf[2]>2)
    { cf add1: real1d_add(`in nxy,u2d[i][k][0],u2d[i][k][1], `out s[i][k][1]);
      for l=2..nf[2]-2 cf add2: real1d_add(`in nxy,s[i][k][l-1],u2d[i][k][l], `out s[i][k][l]);
      cf add3: real1d_add(`in nxy,s[i][k][nf[2]-2],u2d[i][k][nf[2]-1], `out uxy[i][k]);
    }
  }
  cf wrt: write2d_plt(`in str,it,n[0],n[1],nf[0],nf[1],nfs[0],nfs[1],nf0[0],nf0[1],1,uxy,scriptname,prev, `out next);
}

