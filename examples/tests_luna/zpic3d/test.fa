#!/usr/bin/luna
// 3D PIC method with 3D decomposition

#include "lib_basic.fa"
#include "lib_mesh3d.fa"
#include "lib_mesh3d_log.fa"
#include "lib_poisson3d.fa"
#include "lib_mesh3d_exchange_6.fa"
#include "lib_mesh3d_exchange_27.fa"
#include "lib_mesh3d_exchange_sum_27.fa"
#include "lib_mesh3d_exchange_particles_27.fa"

// particles initial density distribution
#define FILL_SQRT  1
#define FILL_EXP   2
#define FILL_LINE  3
#define FILL_CONST 4

#define PI 3.1415926535897932384626433832795

import c_print_memory_usage() as print_memory_usage;
import c_ready_print_memory_usage(`in value `df) as ready_print_memory_usage;

//-----------------------------------------------------------------

import c_print_one_particle(`in string `msg,int `np,value `p) as print_one_particle;

//-----------------------------------------------------------------------------
// Reading parameters
//-----------------------------------------------------------------------------

import c_check_file(`in string `filename, `out name `ok) as check_file;

import c_read_parameters(`in string `filename, `out name `nt,name `nts,name `np,
         name `nx,name `ny,name `nz,       name `nfx,name `nfy,name `nfz,
         name `xn,name `yn,name `zn,       name `tau,name `pm,name `sm,
         name `radius,name `dvr,name `dvf,name `dvz,    name `eps,name `w, name `ok) as read_parameters;

import c_print_parameters(`in int `nt,int `nts,int `np,
                        int `nx,int `ny,int `nz,
                        int `nfx,int `nfy,int `nfz,
                        real `xn,real `yn,real `zn,
                        real `tau,real `pm,real `sm,
                        real `radius,real `dvr,real `dvf,real `dvz,
                        real `eps,real `w) as print_parameters;

import c_print_parameters_seq(`in int `nt,int `nts,int `np,
                        int `nx,int `ny,int `nz,
                        int `nfx,int `nfy,int `nfz,
                        real `xn,real `yn,real `zn,
                        real `tau,real `pm,real `sm,
                        real `radius,real `dvr,real `dvf,real `dvz,
                        real `eps,real `w, value `prev, `out name `next) as print_parameters_seq;

sub init_parameters(`in string args, `out name nt,name nts0,name np0,
                 name n, name nf, name xn, name tau,name pm,name sm,
                 name r0, name dv, name eps,name wp)
// nt      // int : total number of time steps
// nts0    // int : number of time steps between logs 
// np0     // int : minimum required number of particles
// n       // [3] int : 3D mesh sizes
// nf      // [3] int : 3D subdomains grid sizes
// xn      // [3] real : domain sizes
// tau     // real : time step
// pm      // real : particles total mass
// sm      // real : central (sun) mass
// r0      // real : initial distribution parameter: radius
// dv      // [3] real : initial particles distribution parameters: radius, angle and Z velocity dispersions
// eps     // real : Poisson solver precision
// wp      // real : Poisson solver acceleration parameter
{
  df filename,file_ok,seqp;
  // trying to use file name from main(args)
  cf chkfle0: check_file(`in args, `out file_ok[0]);
  if (file_ok[0]!=0) 
  { cf cpfn1: assign_string(`in args, `out filename);
    cf prnfn1: puts_seq("Using parameter file '"+filename+"'",file_ok[0],seqp[1]);
    cf cpfok: copy(`in file_ok[0], `out file_ok[1]);
  }
  // trying to use default file name
  if (file_ok[0]==0)
  { if (args != "") cf prn0: puts_seq("Warning! Can't read provided parameter file '"+args+"'",file_ok[0],seqp[0]);
    if (args == "") cf cpsq0: copy(`in file_ok[0], `out seqp[0]);
    cf cpfn0: assign_string(`in "pic3d.par", `out filename);
    cf chkfle1: check_file(`in filename, `out file_ok[1]);
    if (file_ok[1]!=0) cf prn1: puts_seq("Using default parameter file '"+filename+"'",seqp[0],seqp[1]);
    if (file_ok[1]==0) cf cpsq1: copy(`in seqp[0], `out seqp[1]);
  }
  // if ok trying to read
  if (file_ok[0]!=0 || file_ok[1]!=0)
  { df read_ok;
    cf readpar: read_parameters(`in filename, `out nt,nts0,np0, n[0],n[1],n[2], nf[0],nf[1],nf[2], xn[0],xn[1],xn[2], tau,pm,sm,r0, dv[0],dv[1],dv[2], eps,wp, read_ok);
    if (read_ok==0) cf prnfn0: puts_seq("Reading parameters from file '"+filename+"' failed!",seqp[1], `out seqp[2]);
    if (read_ok!=0) cf cp: copy(`in seqp[1], `out seqp[2]);
  }
  // if not ok using defaults
  if (file_ok[0]==0 && file_ok[1]==0)
  { puts_seq("No default parameter file provided! Using default parameters.",seqp[1], `out seqp[2]);

    cf init_nt: assign_int(`in 10, `out nt);
    cf init_nts: assign_int(`in 1, `out nts0);
    cf init_n0: assign_int(`in 100, `out n[0]);
    cf init_n1: assign_int(`in 100, `out n[1]);
    cf init_n2: assign_int(`in 100, `out n[2]);
    cf init_nf0: assign_int(`in 1, `out nf[0]);
    cf init_nf1: assign_int(`in 1, `out nf[1]);
    cf init_nf2: assign_int(`in 1, `out nf[2]);
    cf init_np0: assign_int(`in 100000, `out np0);

    cf inti_xn0: assign_real(`in 1.0, `out xn[0]);
    cf inti_xn1: assign_real(`in 1.0, `out xn[1]);
    cf inti_xn2: assign_real(`in 1.0, `out xn[2]);
    cf init_tau: assign_real(`in 0.001, `out tau);
    cf init_pm:  assign_real(`in 1.0, `out pm);
    cf init_sm:  assign_real(`in 0.0, `out sm);
    cf init_r0:  assign_real(`in 0.2, `out r0);
    cf init_dvr: assign_real(`in 0.0, `out dv[0]);
    cf init_dvf: assign_real(`in 0.0, `out dv[1]);
    cf init_dvz: assign_real(`in 0.0, `out dv[2]);
    cf init_eps: assign_real(`in 0.001, `out eps);
    cf init_wp:  assign_real(`in 1.8, `out wp);
  }
}

//-----------------------------------------------------------------------------
// Making domain fragmentation
//-----------------------------------------------------------------------------

sub init_subdomains_parameters(`in int nf,name nfs,name nf0,real h, `out name xf1,name xf2)
// nf   : int : number of fragments
// nfs  : [] int : subdomains sizes (with borders)
// nf0  : [] int : subdomains starts (global cell number) (with borders)
// h    : real : mesh step
// xf1  : [nf] real : subdomain starts (global coordinates)
// xf2  : [nf] real : subdomain ends (global coordinates)
{
  for i=0..nf-1
  { cf init_xf1: assign_real(`in (nf0[i]+1)*h, `out xf1[i]);
    cf init_xf2: assign_real(`in (nf0[i]+nfs[i]-1)*h, `out xf2[i]);
  }
}

sub print_subdomains_parameters_seq(`in int nf,name xf1,name xf2,name prev, `out name next)
{ df seq;
  assign(prev,seq[0]);
  for i=0..nf-1 printf_seq("("+xf1[i]+" - "+xf2[i]+")",seq[i],seq[i+1]);
  printf_seq("\n",seq[nf],next);
}

sub print_xyz_seq(`in name nf,name nfs,name nf0,name h,name prev, `out name next)
// nf   : [3] int : 3D subdomains grid sizes
// nfs  : [3][] int : subdomains sizes (with borders)
// nf0  : [3][] int : subdomains starts (global cell number) (with borders)
// h    : [3] real : mesh steps
{
  df seq;
  cf prn0: assign(`in prev, `out seq[0]);
  for i=0..nf[0]-1 cf prnx: print_x_seq(`in i,nfs[0][i],nf0[0][i],h[0],seq[i], `our seq[i+1]);
  for k=0..nf[1]-1 cf prny: print_y_seq(`in k,nfs[1][k],nf0[1][k],h[1],seq[nf[0]+k], `our seq[nf[0]+k+1]);
  for l=0..nf[2]-1 cf prnz: print_z_seq(`in l,nfs[2][l],nf0[2][l],h[2],seq[nf[0]+nf[1]+l], `our seq[nf[0]+nf[1]+l+1]);
  cf prn1: assign(`in seq[nf[0]+nf[1]+nf[2]], `out next);
}

