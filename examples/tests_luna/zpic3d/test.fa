         real `cx,real `cy,real `cz,real `sm,value `fi,value `p,int `np, `out name `prop) as get_properties_subdomain;
import c_get_properties_finish(`in real `am,real `pm,value `prop0, `out name `prop) as get_properties_finish;
import c_print_properties_seq(`in string `filename,value `prop,int `it,real `cx,real `cy,real `cz,value `prev, `out name `next) as print_properties_seq;

//import c_write_particles_part_subdomain(`in string `filename,int `np,value `p,value `prev, `out name next) as write_particles_part_subdomain;
