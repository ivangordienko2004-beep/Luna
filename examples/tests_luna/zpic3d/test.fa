sub get_properties(`in name nf,name nfs,name nf0,name h,name cx,real am,real pm,real sm,name fi,name p,name npfs, `out name prop, `used name used_fi,name used_p)
// nf       : [3] int : 3D subdomains grid sizes
// nfs      : [3][] int : subdomains sizes (with borders)
// nf0      : [3][] int : subdomains starts (global cell number) (with borders)
// h        : [3] real : mesh steps
// cx       : [3] real : coordinates of domain center
// am       : real : single particle mass
// pm       : real : particles total mass
// sm       : real : central (sun) mass
// fi       : [][][] real[][][] : gravitational potential >> used_fi
// p        : [][][] real[][6]: particles >> used_p
// npfs     : [][][] int : number of particles in subdomains >> used_p
// prop     : real[13] : particles properties
{ df pr0, // : [][][] real[13] : particles properties
     pr1; // : real[13] : particles properties
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf getpr0: get_properties_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],h[0],h[1],h[2],cx[0],cx[1],cx[2],
                                            sm,fi[i][k][l],p[i][k][l],npfs[i][k][l], `out pr0[i][k][l]) >> (used_fi[i][k][l],used_p[i][k][l]);
  cf getpr1: array3d_real1d_reduce_sum_real1d(`in nf,13,pr0, `out pr1);
  cf getpr2: get_properties_finish(`in am,pm,pr1, `out prop);
}

