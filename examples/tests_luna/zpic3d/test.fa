import c_init_particles_circle_xz_subdomain(`in int `np,int kind,real `x1,real `y1,real `z1,real `x2,real `y2,real `z2,real `cx,real `cy,real `cz,real `radius, `out name `p,name `npfs) as init_particles_circle_xz_subdomain;
import c_init_particles_circle_yz_subdomain(`in int `np,int kind,real `x1,real `y1,real `z1,real `x2,real `y2,real `z2,real `cx,real `cy,real `cz,real `radius, `out name `p,name `npfs) as init_particles_circle_yz_subdomain;
import c_init_particles_ball_subdomain(`in int `np,int kind,real `x1,real `y1,real `z1,real `x2,real `y2,real `z2,real `cx,real `cy,real `cz,real `radius, `out name `p,name `npfs) as init_particles_ball_subdomain;

import c_init_particles_velocity_z_subdomain(`in int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,
  real `hx,real `hy,real `hz,real `cx,real `cy,real `cz,real `dvr,real `dvf,real `dvz,int `wave,real `tau,real `emax,
