//import c_merge_particles_subdomain(`in value `p1, int `np1, value `p2, int `np2, `out name `p, name `np) as merge_particles_subdomain;

sub init_particles_full(`in int np0,name nf,name xf1,name xf2, `out name p,name npfs,name np)
// np0  : int : minimum required number of particles
// nf   : [3] int : 3D subdomains grid sizes
// xf1  : [3][] real : subdomain starts (global coordinates)
// xf2  : [3][] real : subdomain ends (global coordinates)
// p    : [][][] Particle[]: particles
// npfs : [][][] int : number of particles in subdomains
// np   : int : total number of particles
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf fill: init_particles_full_subdomain(`in np0,xf1[0][i],xf1[1][k],xf1[2][l],xf2[0][i],xf2[1][k],xf2[2][l], `out p[i][k][l],npfs[i][k][l]);
  array3d_int_reduce_sum_int(`in nf,npfs, `out np);
}

sub init_particles_circle_xy(`in int np0,int kind,name nf,name xf1,name xf2,name cx,real r0, `out name p,name npfs,name np)
// np0  : int : minimum required number of particles
// kind : type of initial density ditribution
// nf   : [3] int : 3D subdomains grid sizes
// xf1  : [3][] real : subdomain starts (global coordinates)
// xf2  : [3][] real : subdomain ends (global coordinates)
// cx   : [3] real : coordinates of domain center
// r0   : real : initial distribution parameter: radius
// p    : [][][] Particle[]: particles
// npfs : [][][] int : number of particles in subdomains
// np   : int : total number of particles
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf fill: init_particles_circle_xy_subdomain(`in np0,kind,xf1[0][i],xf1[1][k],xf1[2][l],xf2[0][i],xf2[1][k],xf2[2][l],cx[0],cx[1],cx[2],r0,
                                                `out p[i][k][l],npfs[i][k][l]);
  array3d_int_reduce_sum_int(`in nf,npfs, `out np);
}

sub init_particles_circle_xz(`in int np0,int kind,name nf,name xf1,name xf2,name cx,real r0, `out name p,name npfs,name np)
// np0  : int : minimum required number of particles
