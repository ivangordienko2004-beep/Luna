sub init_particles_ball(`in int np0,int kind,name nf,name xf1,name xf2,name cx,real r0, `out name p,name npfs,name np)
// np0  : int : minimum required number of particles
// kind : type of initial density ditribution
// nf   : [3] int : 3D subdomains grid sizes
// xf1  : [3][] real : subdomain starts (global coordinates)
// xf2  : [3][] real : subdomain ends (global coordinates)
// cx   : [3] real : coordinates of domain center
// r0   : real : initial distribution parameter: radius
// p    : [][][] Particle[]: particles
// npfs : [][][] int : number of particles in subdomains
// np   : int : total number of particles
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf fill: init_particles_ball_subdomain(`in np0,kind,xf1[0][i],xf1[1][k],xf1[2][l],xf2[0][i],xf2[1][k],xf2[2][l],cx[0],cx[1],cx[2],r0,
                                             `out p[i][k][l],npfs[i][k][l]);
  array3d_int_reduce_sum_int(`in nf,npfs, `out np);
}

sub init_particles_velocity_z(`in name nf,name nfs,name nf0,name h,name cx,name dv,int wave,real tau,name fi,name fx,name fy,name fz,name p,name npfs, `out name p_new, `used name used_fi,name used_fxyz,name used_p)
// nf       : [3] int : 3D subdomains grid sizes
// nfs      : [] int : subdomains sizes (with borders)
// nf0      : [] int : subdomains starts (global cell number) (with borders)
// h        : real : mesh step
// cx       : [3] real : coordinates of domain center
// dv       : [3] real : initial distribution parameters: radius, angle and Z velocity dispersions
// wave     : int : number of waves in initial distribution of particles
// tau      : real : time step
// fx,fy,fz : [][][] real[][][] : gravitational forces >> used_fxyz
// fi       : [][][] real[][][] : gravitational potential >> used_fi
// p        : [][][] Particle[]: particles >> used_p
// npfs     : [][][] int : number of particles in subdomains
// p_new    : [][][] Particle[]: particles with velocities set
{
  df seq,
     emax0, // [][][] real : maximum potential energy
     emax;  // real : maximum potential energy
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf maxikl: real1d_reduce_max(`in nfs[0][i]*nfs[1][k]*nfs[2][l],fi[i][k][l], `out emax0[i][k][l]);
  cf max3d: array3d_real_reduce_max_real(`in nf,emax0, `out emax);

  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf initpv: init_particles_velocity_z_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],
                 h[0],h[1],h[2],cx[0],cx[1],cx[2],dv[0],dv[1],dv[2],wave,tau,emax,
                 fx[i][k][l],fy[i][k][l],fz[i][k][l],fi[i][k][l],npfs[i][k][l],p[i][k][l], `out p_new[i][k][l]) >> (used_fi[i][k][l],used_fxyz[i][k][l],used_p[i][k][l]);
}

sub init_particles_velocity_y(`in name nf,name nfs,name nf0,name h,name cx,name dv,int wave,real tau,name fi,name fx,name fy,name fz,name p,name npfs, `out name p_new, `used name used_fi,name used_fxyz,name used_p)
// nf       : [3] int : 3D subdomains grid sizes
// nfs      : [] int : subdomains sizes (with borders)
// nf0      : [] int : subdomains starts (global cell number) (with borders)
// h        : real : mesh step
// cx       : [3] real : coordinates of domain center
// dv       : [3] real : initial distribution parameters: radius, angle and Z velocity dispersions
// wave     : int : number of waves in initial distribution of particles
// tau      : real : time step
// fx,fy,fz : [][][] real[][][] : gravitational forces >> used_fxyz
// fi       : [][][] real[][][] : gravitational potential >> used_fi
// p        : [][][] Particle[]: particles >> used_p
// npfs     : [][][] int : number of particles in subdomains
// p_new    : [][][] Particle[]: particles with velocities set
{
  df seq,
     emax0, // [][][] real : maximum potential energy
     emax;  // real : maximum potential energy
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf maxikl: real1d_reduce_max(`in nfs[0][i]*nfs[1][k]*nfs[2][l],fi[i][k][l], `out emax0[i][k][l]);
  cf max3d: array3d_real_reduce_max_real(`in nf,emax0, `out emax);

  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf initpv: init_particles_velocity_y_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],
                 h[0],h[1],h[2],cx[0],cx[1],cx[2],dv[0],dv[1],dv[2],wave,tau,emax,
                 fx[i][k][l],fy[i][k][l],fz[i][k][l],fi[i][k][l],npfs[i][k][l],p[i][k][l], `out p_new[i][k][l]) >> (used_fi[i][k][l],used_fxyz[i][k][l],used_p[i][k][l]);
}

sub init_particles_velocity_x(`in name nf,name nfs,name nf0,name h,name cx,name dv,int wave,real tau,name fi,name fx,name fy,name fz,name p,name npfs, `out name p_new, `used name used_fi,name used_fxyz,name used_p)
// nf       : [3] int : 3D subdomains grid sizes
// nfs      : [] int : subdomains sizes (with borders)
// nf0      : [] int : subdomains starts (global cell number) (with borders)
// h        : real : mesh step
// cx       : [3] real : coordinates of domain center
// dv       : [3] real : initial distribution parameters: radius, angle and Z velocity dispersions
// wave     : int : number of waves in initial distribution of particles
// tau      : real : time step
// fx,fy,fz : [][][] real[][][] : gravitational forces >> used_fxyz
// fi       : [][][] real[][][] : gravitational potential >> used_fi
// p        : [][][] Particle[]: particles >> used_p
// npfs     : [][][] int : number of particles in subdomains
// p_new    : [][][] Particle[]: particles with velocities set
{
  df seq,
     emax0, // [][][] real : maximum potential energy
     emax;  // real : maximum potential energy
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf maxikl: real1d_reduce_max(`in nfs[0][i]*nfs[1][k]*nfs[2][l],fi[i][k][l], `out emax0[i][k][l]);
  cf max3d: array3d_real_reduce_max_real(`in nf,emax0, `out emax);

  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf initpv: init_particles_velocity_x_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],
                 h[0],h[1],h[2],cx[0],cx[1],cx[2],dv[0],dv[1],dv[2],wave,tau,emax,
                 fx[i][k][l],fy[i][k][l],fz[i][k][l],fi[i][k][l],npfs[i][k][l],p[i][k][l], `out p_new[i][k][l]) >> (used_fi[i][k][l],used_fxyz[i][k][l],used_p[i][k][l]);
}

sub init_particles_velocity_ball(`in name nf,name nfs,name nf0,name h,name cx,name dv,real tau,name fi,name fx,name fy,name fz,name p,name npfs, `out name p_new, `used name used_fi,name used_fxyz,name used_p)
// nf       : [3] int : 3D subdomains grid sizes
// nfs      : [] int : subdomains sizes (with borders)
// nf0      : [] int : subdomains starts (global cell number) (with borders)
// h        : real : mesh step
// cx       : [3] real : coordinates of domain center
// dv       : [3] real : initial distribution parameters: radius, angle and Z velocity dispersions
// tau      : real : time step
// fx,fy,fz : [][][] real[][][] : gravitational forces >> used_fxyz
// fi       : [][][] real[][][] : gravitational potential >> used_fi
// p        : [][][] Particle[]: particles >> used_p
// npfs     : [][][] int : number of particles in subdomains
// p_new    : [][][] Particle[]: particles with velocities set
{
  df //seq,
     emax0, // [][][] real : maximum potential energy
     emax;  // real : maximum potential energy
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf maxikl: real1d_reduce_max(`in nfs[0][i]*nfs[1][k]*nfs[2][l],fi[i][k][l], `out emax0[i][k][l]);
  cf max3d: array3d_real_reduce_max_real(`in nf,emax0, `out emax);

  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf initpv: init_particles_velocity_ball_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],
                 h[0],h[1],h[2],cx[0],cx[1],cx[2],dv[0],dv[1],dv[2],tau,emax,
                 fx[i][k][l],fy[i][k][l],fz[i][k][l],fi[i][k][l],npfs[i][k][l],p[i][k][l], `out p_new[i][k][l]) >> (used_fi[i][k][l],used_fxyz[i][k][l],used_p[i][k][l]);
}

/*
sub merge_particles(`in name nf, name p1, name npfs1, name p2, name npfs2, `out name p, name npfs, `used name used_p1, name used_npfs1, name used_p2, name used_npfs2)
// nf       : [3] int : 3D subdomains grid sizes
// p1       : [][][] Particle[]: particles >> used_p1
// npfs1    : [][][] int : number of particles in subdomains
// p2       : [][][] Particle[]: particles >> used_p2
// npfs2    : [][][] int : number of particles in subdomains
// p        : [][][] Particle[]: particles
// npfs     : [][][] int : number of particles in subdomains
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf merge_p: merge_particles_subdomain(`in p1[i][k][l], npfs1[i][k][l], p2[i][k][l], npfs2[i][k][l], `out p[i][k][l], npfs[i][k][l]) >> (used_p1[i][k][l],used_npfs1[i][k][l],used_p2[i][k][l],used_npfs2[i][k][l]);
}
*/
sub print_particles_seq(`in name nf,name p,name npfs,name prev, `out name next)
{ df seq;
  assign(prev,seq[0]);
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 let ikl=i*nf[1]*nf[2]+k*nf[2]+l puts_seq("np["+i+"]["+k+"]["+l+"]: "+npfs[i][k][l],seq[ikl],seq[ikl+1]);
  assign(seq[nf[0]*nf[1]*nf[2]],next);
}

// ----------------------------------------------------------------------------------------------------------------------
// Compute subroutines
// ----------------------------------------------------------------------------------------------------------------------

import c_init_array3d_subdomain(`in int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,real `hx,real `hy,real `hz, `out name `u) as init_array3d_subdomain;
import c_density_subdomain(`in int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,real `hx,real `hy,real `hz,real `am,value `p,int `np, `out name `ro) as density_subdomain;

import c_init_fi_subdomain(`in int `nfx,int `nfy,int `nfz,int `ifx,int `ify,int `ifz,
              int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,
              real `hx,real `hy,real `hz,real `cx,real `cy,real `cz,real `mass, `out name `fi) as init_fi_subdomain;

import c_fi_dobavka_subdomain(`in int `nfx,int `nfy,int `nfz,int `ifx,int `ify,int `ifz,
                                  int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,real `hx,real `hy,real `hz,real `cx,real `cy,real `cz,real `sm,value `fp, `out name `fi) as fi_dobavka_subdomain;

import c_force_subdomain(`in int `nx,int `ny,int `nz,real `hx,real `hy,real `hz,value `fi, `out name `fx,name `fy,name `fz) as force_subdomain;

import c_move_particles_subdomain(`in int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,real `hx,real `hy,real `hz,
              value `fx,value `fy,value `fz,real `tau,int `np,value `p, `out name `pnew) as move_particles_subdomain;

sub init_array3d(`in name nf,name nfs,name nf0,name h, `out name u)
// nf   : [3] int : 3D subdomains grid sizes
// nfs  : [3][] int : subdomains sizes (with borders)
// nf0  : [3][] int : subdomains starts (global cell number) (with borders)
// h    : [3] real : mesh steps
// u    : [][][] real[][][] : fragmented array to be set
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf init_e: init_array3d_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],h[0],h[1],h[2], `out u[i][k][l]);
}

sub density(`in name nf,name nfs,name nf0,name h,real am,name p,name npfs, `out name ro,name used_p)
// nf   : [3] int : 3D subdomains grid sizes
// nfs  : [3][] int : subdomains sizes (with borders)
// nf0  : [3][] int : subdomains starts (global cell number) (with borders)
// h    : [3] real : mesh steps
// am   : real : single particle mass
// p    : [][][] Particle[]: particles >> used_p
// npfs : [][][] int : number of particles in subdomains >> used_p
// ro   : [][][] real[][][] : density
{
  df ro0; // : [][][] real[] : density before exchange
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf dens: density_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],h[0],h[1],h[2],am,p[i][k][l],npfs[i][k][l], `out ro0[i][k][l]) >> (used_p[i][k][l]);
  cf dex: mesh3d_exchange_sum_27(`in nf,nfs,ro0, `out ro);
}

sub move_particles(`in name nf,name nfs,name nf0,name h,name xf1,name xf2,name fx,name fy,name fz,real tau,name npfs,name p, `out name npfsnew,name pnew,name used_fxyz,name used_p)
// nf       : [3] int : 3D subdomains grid sizes
// nfs      : [3][] int : subdomains sizes (with borders)
// nf0      : [3][] int : subdomains starts (global cell number) (with borders)
// h        : [3] real : mesh steps
// xf1      : [3][] real : subdomain starts (global coordinates)
// xf2      : [3][] real : subdomain ends (global coordinates)
// fx,fy,fz : [][][] real[][][] : gravitational forces >> used_fxyz
// tau      : real : time step
// npfs     : [][][] int : number of particles in subdomains >> used_p
// p        : [][][] Particle[]: particles >> used_p
// npfsnew  : [][][] int : new number of particles in subdomains
// pnew     : [][][] Particle[]: new particles
{
  df pt; // [][][] Particle[] : particles after move before exchange
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf move: move_particles_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],h[0],h[1],h[2],
               fx[i][k][l],fy[i][k][l],fz[i][k][l],tau,npfs[i][k][l],p[i][k][l], `out pt[i][k][l]) >> (used_fxyz[i][k][l]);
  cf pex: mesh3d_exchange_particles_27(`in nf,npfs,pt,xf1,xf2, `out npfsnew,pnew, `used used_p);
}

sub init_poisson(`in name nf,name nfs,name nf0,name h,name cx,real mass, `out name fi)
// nf   : [3] int : 3D subdomains grid sizes
// nfs  : [3][] int : subdomains sizes (with borders)
// nf0  : [3][] int : subdomains starts (global cell number) (with borders)
// h    : [3] real : mesh steps
// cx   : [3] real : coordinates of domain center
// mass : real : total mass of the gravitating system
// fi   : [][][] real[][][] : gravitational potential
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf init_fi: init_fi_subdomain(`in nf[0],nf[1],nf[2],i,k,l,nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],
                                      h[0],h[1],h[2],cx[0],cx[1],cx[2],mass, `out fi[i][k][l]);
}

sub fi_dobavka(`in name nf,name nfs,name nf0,name h,name cx,real sm,name fp, `out name fi, `used name used_fp)
// nf   : [3] int : 3D subdomains grid sizes
// nfs  : [3][] int : subdomains sizes (with borders)
// nf0  : [3][] int : subdomains starts (global cell number) (with borders)
// h    : [3] real : mesh steps
// cx   : [3] real : coordinates of domain center
// sm   : real : central body mass (sun)
// fp   : [][][] real[][][] : gravitational potential without addition >> used_fp
// fi   : [][][] real[][][] : gravitational potential with addition
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf init_fi: fi_dobavka_subdomain(`in nf[0],nf[1],nf[1],i,k,l,
                                      nfs[0][i],nfs[1][k],nfs[2][l],nf0[0][i],nf0[1][k],nf0[2][l],
                                      h[0],h[1],h[2],cx[0],cx[1],cx[2],sm,fp[i][k][l], `out fi[i][k][l]) >> (used_fp[i][k][l]);
}

sub force(`in name nf,name nfs,name h,name fi, `out name fx,name fy,name fz, `used name used_fi)
// nf       : [3] int : 3D subdomains grid sizes
// nfs      : [3][] int : subdomains sizes (with borders)
// h        : [3] real : mesh steps
// fi       : [][][] real[][][] : gravitational potential >> used_fi
// fx,fy,fz : [][][] real[][][] : gravitational forces
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf frc: force_subdomain(`in nfs[0][i],nfs[1][k],nfs[2][l],h[0],h[1],h[2],fi[i][k][l], `out fx[i][k][l],fy[i][k][l],fz[i][k][l]) >> (used_fi[i][k][l]);
}

