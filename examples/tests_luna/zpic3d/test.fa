import c_print_z(`in int `ifz,int `nz,int `sz,real `hz) as print_z;

import c_print_x_seq(`in int `ifx,int `nx,int `sx,real `hx,value `prev, `out name `next) as print_x_seq;
import c_print_y_seq(`in int `ify,int `ny,int `sy,real `hy,value `prev, `out name `next) as print_y_seq;
import c_print_z_seq(`in int `ifz,int `nz,int `sz,real `hz,value `prev, `out name `next) as print_z_seq;

sub free3d_if1(`in name nf,name a3d,name df_check)
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf free: empty(`in df_check) --> (a3d[i][k][l]);
}

sub empty3d_0(`in name nf, `out name v)
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf emp: empty0() >> (v[i][k][l]);
}

sub empty3d_1(`in name nf,name v1, `out name v)
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf emp: empty1(`in v1[i][k][l]) >> (v[i][k][l]);
}

sub empty3d_2(`in name nf,name v1,name v2, `out name v)
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf emp: empty2(`in v1[i][k][l],v2[i][k][l]) >> (v[i][k][l]);
}

sub empty3d_3(`in name nf,name v1,name v2,name v3, `out name v)
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf emp: empty3(`in v1[i][k][l],v2[i][k][l],v3[i][k][l]) >> (v[i][k][l]);
}
sub empty3d_4(`in name nf,name v1,name v2,name v3,name v4, `out name v)
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf emp: empty4(`in v1[i][k][l],v2[i][k][l],v3[i][k][l],v4[i][k][l]) >> (v[i][k][l]);
}
sub empty3d_5(`in name nf,name v1,name v2,name v3,name v4,name v5, `out name v)
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf emp: empty5(`in v1[i][k][l],v2[i][k][l],v3[i][k][l],v4[i][k][l],v5[i][k][l]) >> (v[i][k][l]);
}
sub empty3d_6(`in name nf,name v1,name v2,name v3,name v4,name v5,name v6, `out name v)
{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1 cf emp: empty6(`in v1[i][k][l],v2[i][k][l],v3[i][k][l],v4[i][k][l],v5[i][k][l],v6[i][k][l]) >> (v[i][k][l]);
}

//================================================================================================================================================

sub main(string args)
{
  df nt,          // int : total number of time steps
     nts0,nts,    // int : number of time steps between logs 
     n,           // [3] int : 3D mesh sizes
     nf,          // [3] int : 3D subdomains grid sizes
     nfs,         // [3][] int : subdomains sizes (with borders)
     nf0,         // [3][] int : subdomains starts (global cell number) (with borders)
     np0,         // int : minimum required number of particles
     np,          // int : total number of particles
     npfs,        // [nt] [][][] int : number of particles in subdomains
     p,pt,px,     // [nt] [][][] real[][6] double: particles
     ro,          // [][][] real[][][] : density
     fi0,         // [][][] real[][][] : initial gravitational potential
     fp,fi,       // [nt] [][][] real[][][] : gravitational potential
     fx,fy,fz,    // [nt] [][][] real[][][] : gravitational forces
     xn,          // [3] real : domain sizes
     cx,          // [3] real : coordinates of domain centre
     xf1,         // [3][*] real : subdomain starts (global coordinates) (without borders)
     xf2,         // [3][*] real : subdomain ends (global coordinates) (without borders)
     pm,          // real : particles total mass
     am,          // real : single particle mass
     sm,          // real : central (sun) mass
     r0,          // real : initial distribution parameter: radius
     dv,          // [3] real : initial particles distribution parameters: radius, angle and Z velocity dispersions
     eps,         // real : Poisson solver precision
     wp,          // real : Poisson solver acceleration parameter
     h,           // [3] real : mesh step
     tau,         // real : time step
     count,       // [] int : total number of Poisson solver iterations
     prop,        // [] Properties : properties of particles system
     seq,seqlog,seqplt,
     used_px_density,used_fi0_poisson,used_px_velocity,used_fi_velocity,used_fxyz_velocity,
     used_p_density,used_p_move,used_fxyz_move,
     used_fp_poisson,used_fp_dobavka,used_fi_force,
     used_fi_prop,used_p_prop,
     used_ro_log,
     ready_it,
     used_fi_log,used_fp_log,used_fx_log,used_fy_log,used_fz_log,used_p_log;

  // parameters initialization
  cf initpar: init_parameters(`in args, `out nt,nts0,np0, n, nf, xn, tau,pm,sm,r0, dv, eps,wp);
  cf printpar: print_parameters(`in nt,nts0,np0, n[0],n[1],n[2], nf[0],nf[1],nf[2], xn[0],xn[1],xn[2], tau,pm,sm,r0, dv[0],dv[1],dv[2], eps,wp);
// was here /*
  if (nts0 != 0) assign_int(`in nts0, `out nts);
  if (nts0 == 0) assign_int(`in nt+1, `out nts);

  cf init_h0: assign_real(`in xn[0]/n[0], `out h[0]);
  cf init_h1: assign_real(`in xn[1]/n[1], `out h[1]);
  cf init_h2: assign_real(`in xn[2]/n[2], `out h[2]);
  cf init_cx0: assign_real(`in xn[0]/2.0, `out cx[0]);
  cf init_cx1: assign_real(`in xn[1]/2.0, `out cx[1]);
  cf init_cx2: assign_real(`in xn[2]/2.0, `out cx[2]);
  cf init_am: assign_real(`in pm/np, `out am);

  // make fragmentation
  cf frag_mesh: make_mesh3d_fragmentation(`in n,nf,1, `out nfs,nf0);

  assign_int(`in 1, `out seq[0]);
  assign_int(`in 1, `out ready_it[0-1]);

  //print_mesh3d_fragmentation_seq(`in n,nf,nfs,nf0,seq[0],seq[3]);

  cf frag_sub0: init_subdomains_parameters(`in nf[0],nfs[0],nf0[0],h[0], `out xf1[0],xf2[0]);
  cf frag_sub1: init_subdomains_parameters(`in nf[1],nfs[1],nf0[1],h[1], `out xf1[1],xf2[1]);
  cf frag_sub2: init_subdomains_parameters(`in nf[2],nfs[2],nf0[2],h[2], `out xf1[2],xf2[2]);

//  print_subdomains_parameters_seq(nf[0],xf1[0],xf2[0],seq[3],seq[4]);
//  print_subdomains_parameters_seq(nf[1],xf1[1],xf2[1],seq[4],seq[5]);
//  print_subdomains_parameters_seq(nf[2],xf1[2],xf2[2],seq[5],seq[6]);
  //cf pxyz: print_xyz_seq(`in nf,nfs,nf0,h,seq[6], `out seq[7]);

  gnuplot_script_init("dopng.plt",seqplt[0]);

  // data initialization
  //cf initp: init_particles_uniform(`in np0,nf,xf1,xf2,cx,r0,dv, `out p[0],npfs[0],np);
  cf initp: init_particles_circle_yz(`in np0,$FILL_CONST,nf,xf1,xf2,cx,r0, `out px,npfs[0],np);
  //cf initp: init_particles_ball(`in np0,$FILL_CONST,nf,xf1,xf2,cx,r0, `out px,npfs[0],np);
  //print_particles_seq(nf,px,npfs[0],seq[1],seq[2]);

  if (np0 != np) puts("Actual number of particles: "+np);

  cf dens0: density(`in nf,nfs,nf0,h,am,px,npfs[0], `out ro[0], `used used_px_density);
  cf ipoi: init_poisson(`in nf,nfs,nf0,h,cx,pm, `out fi0);
  cf poi0: poisson3d_solve_explicit(`in nf,nfs,h,wp,eps,4*$PI,1,ro[0],fi0, `out fp[0],count[0], `used used_fi0_poisson);
  cf pad0: fi_dobavka(`in nf,nfs,nf0,h,cx,sm,fp[0], `out fi[0], `used used_fp_dobavka[0]);

  puts("Poisson ["+0+"] : "+count[0]);
