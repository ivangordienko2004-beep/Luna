import c_init_particles_velocity_y_subdomain(`in int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,
  real `hx,real `hy,real `hz,real `cx,real `cy,real `cz,real `dvr,real `dvf,real `dvy,int `wave,real `tau,real `emax,
  value `fi,value `fx,value `fy,value `fz,int `np,value `p, `out name `p_new) as init_particles_velocity_y_subdomain;
import c_init_particles_velocity_x_subdomain(`in int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,
  real `hx,real `hy,real `hz,real `cx,real `cy,real `cz,real `dvr,real `dvf,real `dvz,int `wave,real `tau,real `emax,
  value `fi,value `fx,value `fy,value `fz,int `np,value `p, `out name `p_new) as init_particles_velocity_x_subdomain;

import c_init_particles_velocity_ball_subdomain(`in int `nx,int `ny,int `nz,int `sx,int `sy,int `sz,
  real `hx,real `hy,real `hz,real `cx,real `cy,real `cz,real `dvr,real `dvf,real `dvz,real `tau,real `emax,
