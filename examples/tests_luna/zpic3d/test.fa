{
  for i=0..nf[0]-1 for k=0..nf[1]-1 for l=0..nf[2]-1
    cf fill: init_particles_circle_yz_subdomain(`in np0,kind,xf1[0][i],xf1[1][k],xf1[2][l],xf2[0][i],xf2[1][k],xf2[2][l],cx[0],cx[1],cx[2],r0,
                                                `out p[i][k][l],npfs[i][k][l]);
  array3d_int_reduce_sum_int(`in nf,npfs, `out np);
