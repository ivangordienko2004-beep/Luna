/*
 Initialization of data fragments and data dependencies.
*/

import c_init(int, name) as init;
import c_iprint(int) as iprint;

sub main()
{
	df x;

	cf a: init(7, x[4]) @ {
		req_count x[1+3]=1;
		locator_cyclic: 1;
	};

	iprint(x[2+2]) @ {
//		request x[2*2];
		locator_cyclic: 2;
	};

} @ {
	locator_cyclic x[i] => 3;
}

