
import assign_double(name, real);
import show_double(string, real) as show;

sub main()
{
    df x;
    cf a: assign_double(x, 0.5) @ {req_count x=4; locator_cyclic: 1;};
	for i=1..4
            show("i = " + i + ": ",
                0 >= -i--1*--1 && -i > -4 ?
                (4*-i%10)*--real(x)*-1*(-i--3*i+-i*2-1*-100)+-(120+-100)*(-5)+-real(1)/-i
                : -(-1.0/3*-(-(-3))/100)
            ) @ { request x; locator_cyclic: 1; };
}
